generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id        String    @id @default(cuid())
  userId    String
  fileUrl   String
  status    JobStatus @default(PENDING)
  transcript String? @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
